# Copy to .env only if you need to override defaults:  cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────────────────
# 1. Local development
# ─────────────────────────────────────────────────────────────────────────────
# Nothing is required. Generation runs through Ollama at the default local URL and
# the dev-bypass dashboard needs no login. Optional: skip Redis/Celery —
# DEJAQ_USE_CELERY=false
#
# Generation backend (Ollama, local or remote). Default is local:
# DEJAQ_OLLAMA_URL=http://127.0.0.1:11434

# ─────────────────────────────────────────────────────────────────────────────
# 2. Dashboard auth (optional — deployment only)
# ─────────────────────────────────────────────────────────────────────────────
# Blank = dev bypass (DEJAQ_AUTH_MODE auto-selects "local"). Fill both to require
# real Supabase login (DEJAQ_AUTH_MODE auto-selects "supabase").
# SUPABASE_URL=https://<project-id>.supabase.co
# SUPABASE_ANON_KEY=eyJ...
# DEJAQ_AUTH_MODE=local        # force "local" or "supabase"; auto-detected by default

# ─────────────────────────────────────────────────────────────────────────────
# 3. External LLM providers (optional — only for hard-query routing)
# ─────────────────────────────────────────────────────────────────────────────
# Fernet key that encrypts org provider API keys stored in the DB. Required only
# before saving an OpenAI/Anthropic/Google credential. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Back it up — losing it makes stored credentials unrecoverable.
# DEJAQ_CREDENTIAL_ENCRYPTION_KEY=

# Full list of advanced/runtime tuning vars (model backends, Chroma/Redis hosts,
# eviction floor, log levels, etc.) is documented in CLAUDE.md.
