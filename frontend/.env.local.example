# Copy to .env.local:  cp .env.local.example .env.local

# Backend management API base URL
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Supabase dashboard auth — leave blank for local dev (dev bypass, no login).
# Fill both only to enable real Supabase email/password login.
# NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
