# Copy this file to .env and fill in your values
# cp .env.example .env

# ── External LLM ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# Model to use for hard prompts (default: gpt-4o)
# DEJAQ_EXTERNAL_MODEL=gpt-4o

# Custom OpenAI-compatible endpoint (e.g. vLLM, Ollama) — optional
# DEJAQ_EXTERNAL_API_BASE=https://api.openai.com/v1

# ── Redis ─────────────────────────────────────────────────────────────────────
# DEJAQ_REDIS_URL=redis://localhost:6379/0

# ── ChromaDB ──────────────────────────────────────────────────────────────────
# DEJAQ_CHROMA_HOST=127.0.0.1
# DEJAQ_CHROMA_PORT=8001

# ── Feature Flags ─────────────────────────────────────────────────────────────
# DEJAQ_USE_CELERY=true

# ── Cache Feedback Thresholds ─────────────────────────────────────────────────
# DEJAQ_TRUSTED_THRESHOLD=3
# DEJAQ_FLAG_THRESHOLD=-3
# DEJAQ_AUTO_DELETE_THRESHOLD=-5
# DEJAQ_TRUSTED_SIMILARITY=0.20
# DEJAQ_SUPPRESSION_TTL=300
